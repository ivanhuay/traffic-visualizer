{
  "name": "traffic-visualizer",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel --filter './packages/*' dev",
    "build": "pnpm --filter './packages/*' build",
    "test": "pnpm --filter './packages/*' test",
    "lint": "pnpm --filter './packages/*' lint",
    "format": "prettier --write \"**/*.{ts,tsx,json,scss,md}\"",
    "traffic-gen": "tsx scripts/traffic-gen.ts",
    "traffic-gen:burst": "tsx scripts/traffic-gen.ts --burst",
    "traffic-gen:fast": "tsx scripts/traffic-gen.ts --rate=10",
    "traffic-gen:errors": "tsx scripts/traffic-gen.ts --errors",
    "traffic-gen:chaos": "tsx scripts/traffic-gen.ts --rate=8 --errors"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "eslint": "^9.9.0",
    "@typescript-eslint/eslint-plugin": "^8.3.0",
    "@typescript-eslint/parser": "^8.3.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "tsx": "^4.19.0"
  }
}
